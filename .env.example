# CRICMIND — Environment Variables
# ═══════════════════════════════════════
# Copy this file to .env.local and fill in your keys

# Cricket Data API (https://cricketdata.org)
# Sign up for free, get 100 hits/day
CRICKET_API_KEY=YOUR_API_KEY_HERE

# Anthropic Claude API (https://console.anthropic.com)
# For AI-powered analysis, chat, and predictions
ANTHROPIC_API_KEY=YOUR_API_KEY_HERE
